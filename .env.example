# Shadow v8 environment template

# Bybit
BYBIT_ENABLED=true
BYBIT_PAPER=false
BASE_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=

# IBKR is disabled until IB Gateway / paper flow is ready.
IBKR_ENABLED=false
IBKR_PAPER=true
IBKR_ACCOUNT_ID=

# Trading controls
CRYPTO_LIVE_TRADING_ENABLED=false
STOCKS_ENABLED=true
STOCK_LIVE_TRADING_ENABLED=false
STOCK_SHORTS_ENABLED=false
SCAN_INTERVAL_SEC=300
SHADOW_RUN_ONCE=false
SHADOW_EXECUTION_MODE=scan_only
PAPER_ACCOUNT_BALANCE=10000
PAPER_TAKE_PROFIT_R=2.0
PAPER_PARTIAL_R=1.0
PAPER_PARTIAL_FRACTION=0.40
PAPER_BREAK_EVEN_R=1.2
PAPER_TRAIL_START_R=3.0
PAPER_TRAIL_GIVEBACK_R=1.0
MIN_STOP_PCT=0.01

# Scanner
STOCK_MIN_PRICE=5
STOCK_MIN_AVG_DOLLAR_VOLUME=20000000
STOCK_SCANNER_MAX_RESULTS=200
CRYPTO_SCAN_ENABLED=true
CRYPTO_SCAN_ALL_USDT=false
CRYPTO_SCAN_MAX_SYMBOLS=25
CRYPTO_SCAN_SYMBOLS=ETHUSDT,BTCUSDT,SOLUSDT,BNBUSDT,XRPUSDT,LINKUSDT,AVAXUSDT

# Stock market price data
# Stooq is tried first; Yahoo chart fallback is automatic if Stooq is unavailable.
STOCK_MARKET_DATA_SOURCE=stooq
STOCK_MARKET_DATA_TIMEOUT_SEC=10
STOOQ_SUFFIX=us

# Risk
MAX_OPEN_POSITIONS_TOTAL=3
MAX_OPEN_CRYPTO_POSITIONS=1
MAX_OPEN_STOCK_POSITIONS=3
DAILY_R_LIMIT=-2.0
STOCK_NORMAL_MAX_ACCOUNT_RISK_PCT=0.015
STOCK_IDEAL_STOP_MIN_PCT=2.5
STOCK_IDEAL_STOP_MAX_PCT=5.0
STOCK_MAX_POSITION_PCT=0.25
DEFAULT_CRYPTO_RISK_PCT=0.03

# Earnings
EARNINGS_BLOCK_DAYS=5
ALLOW_POST_EARNINGS_SETUPS=true

# Fundamentals
# Use STOCK_FUNDAMENTALS_SOURCE=sec to test official SEC Company Facts growth data.
# SEC requests should include a real contact-style user agent.
STOCK_FUNDAMENTALS_SOURCE=demo
STOCK_FUNDAMENTALS_SYMBOL=NVDA
SEC_USER_AGENT=Shadow v8 research your-email@example.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_TOP_SETUP_MIN_SCORE=45
TELEGRAM_TOP_SETUP_COOLDOWN_SEC=3600
TELEGRAM_MONITOR_COOLDOWN_SEC=1800
TELEGRAM_PAPER_ENTRY_ALERTS=true
TELEGRAM_ENGINE_WARNING_ALERTS=true
# Telegram commands are enabled automatically when alerts are enabled and credentials are present.

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8501
DASHBOARD_TOKEN=
